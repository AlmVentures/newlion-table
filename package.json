{
  "name": "@newlion/table",
  "version": "0.1.0",
  "type": "module",
  "description": "A reusable, data-agnostic data table shell for React, built on TanStack Table and shadcn/ui.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlmVentures/newlion-table.git"
  },
  "bugs": {
    "url": "https://github.com/AlmVentures/newlion-table/issues"
  },
  "homepage": "https://github.com/AlmVentures/newlion-table#readme",
  "keywords": [
    "react",
    "table",
    "data-table",
    "datatable",
    "tanstack-table",
    "react-table",
    "shadcn",
    "shadcn-ui",
    "typescript"
  ],
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^0.468.0 || ^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
